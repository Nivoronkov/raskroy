# --- виртуальная среда (никогда не коммитится, у каждого своя) ---
venv/
.venv/

# --- кэш Python ---
__pycache__/
*.pyc
*.pyo

# --- рабочие файлы: спецификации и результаты раскроя ---
# Их не храним в репозитории кода. Исключение — тестовые эталоны (см. ниже).
*.xls
*_вход.xlsx
*_раскрой.xlsx

# --- логи ---
*.log
logs/

# --- системное ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- ИСКЛЮЧЕНИЕ: тестовые файлы-эталоны коммитим (нужны для тестов) ---
!tests/data/*.xls

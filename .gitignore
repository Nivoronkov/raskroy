# --- виртуальная среда (никогда не коммитится, у каждого своя) ---
venv/
.venv/
env/

# --- кэш Python ---
__pycache__/
*.pyc
*.pyo
*.py[cod]
.pytest_cache/

# --- рабочие файлы: спецификации и результаты раскроя ---
# их не храним в репозитории кода. Исключение — тестовые эталоны (см. ниже).
*.xls
*.xlsx
*_вход.xlsx
*_раскрой.xlsx
результат_*.xlsx

# --- справочники: НЕ коммитим (формируются при запуске, ведутся общим файлом в сети) ---
smart_cut_app/materials_catalog.json
smart_cut_app/leftovers_db.json
smart_cut_app/app_config.json

# --- бэкапы наших правок (не нужны в репозитории) ---
*_BAK.py
*_BAK2.py
*_BAK3.py
*_ДО_ЗАМЕНЫ.py
*_до_замены.py
*_backup.py

# --- личные заметки ---
Работа с гитхаб.txt

# --- логи ---
*.log
logs/

# --- системное / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- ИСКЛЮЧЕНИЯ: тестовые файлы-эталоны коммитим (нужны для тестов) ---
!tests/data/*.xls
!tests/data/*.xlsx
